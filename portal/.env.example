# API base (proxied to Flask via vite.config.js by default)
VITE_API_BASE_URL=/api

# Project credentials (must match a Project row in PostgreSQL)
VITE_PROJECT_ID=proj_demo_local
VITE_API_KEY=demo_api_key_local_dev

# Set to "true" to force the high-fidelity mock dataset (no backend needed)
VITE_USE_MOCK=false
